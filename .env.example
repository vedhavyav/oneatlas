# Gemini API Key (Required for app generation and AI gateway features)
GEMINI_API_KEY=your_gemini_api_key_here

# Clerk Authentication (Required for tenant authentication and auth routes)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Neon PostgreSQL Database Connection (Standard or Pooling)
DATABASE_URL="postgresql://user:password@ep-host.region.pooler.neon.tech/neondb?sslmode=require"

# Platform Configuration
PORT=3000
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RUNTIME_URL=http://localhost:3002
